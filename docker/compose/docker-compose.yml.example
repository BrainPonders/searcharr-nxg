# owner: project maintainer
# date: 2026-03-23
# service: searcharr-nxg
# purpose: production-oriented compose example for Searcharr-nxg
# docs: README.md, docker/compose/.env.example
# deployment notes:
#   - Provide a real settings.py outside the repository before starting the container.
#   - The scaffold runtime is long-lived but does not yet implement the Telegram service loop.
# history:
#   - 2026-03-10: Initialized generic template example.
#   - 2026-03-23: Adapted the example for Searcharr-nxg.

services:
  app:
    image: ${PROJECT_IMAGE}
    container_name: ${PROJECT_CONTAINER_NAME:-searcharr-nxg}
    restart: unless-stopped

    env_file:
      - .env

    environment:
      SEARCHARR_SETTINGS_FILE: /app/settings.py

    volumes:
      - "${PROJECT_SETTINGS_FILE:-./config/settings.py}:/app/settings.py:ro"
      - ./data:/app/data
